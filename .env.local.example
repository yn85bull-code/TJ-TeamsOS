# Supabase Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Recommended current key name
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Legacy key name is also supported by the app if you use an anon key instead.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Do not expose service_role in browser code.
# Keep it unset unless a server-only admin script is added later.
SUPABASE_SERVICE_ROLE_KEY=
